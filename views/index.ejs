<!DOCTYPE html>
<html>
	<head>
		<meta charset="utf-8"/>
		<link rel="stylesheet" href="bulma.min.css">
		<script defer src="https://use.fontawesome.com/releases/v5.3.1/js/all.js"> </script>
	</head>
	<body>
		<section class="section">
			<div class="maincolumns columns is-desktop is-vcentered">
				<div class="column is-10 is-offset-1 notification is-info is-light box container">
					<div class="title">
						Web Users
					</div>
					<% if (locals.allUsers) { %>
						<div class="table-container">
						<table class="table is-bordered is-hoverable is-striped is-narrow">
							<thead>
							<tr>
								<th> First Name </th>
								<th> Last Name </th>
								<th> Email </th>
							</tr>
							</thead>
							<% let i=0; %>
							<% for(i=0; i < allUsers.length; i++) { %>
							<tr>
								<td><%= allUsers[i].first_name %></td>
								<td><%= allUsers[i].last_name %></td>
								<td><%= allUsers[i].email %></td>
							</tr>
							<% } %>
							<tfoot>
								<tr> <td colspan="4">
								There are <%= i %> users.
								</td> </tr>
							</tfoot>
						</table>
						<form action="/addUser" method="POST">
                            <h2 class="subtitle">Add New User</h2>
                            <div class="field is-horizontal">
                                <div class="field-body">
                                    <div class="field">
                                        <p class="control is-expanded">
                                            <input name="first_name" class="input" type="text" placeholder="First Name" required>
                                        </p>
                                    </div>
                                    <div class="field">
                                        <p class="control is-expanded">
                                            <input name="last_name" class="input" type="text" placeholder="Last Name" required>
                                        </p>
                                    </div>
                                    <div class="field">
                                        <p class="control is-expanded">
                                            <input name="email" class="input" type="email" placeholder="Email" required>
                                        </p>
                                    </div>
                                    <div class="field">
                                        <p class="control is-expanded">
                                            <input name="password" class="input" type="password" placeholder="Password" required>
                                        </p>
                                    </div>
                                    <div class="field">
                                        <button type="submit" class="button is-link">
                                            <span class="icon is-small">
                                                <i class="fas fa-user-plus"></i>
                                            </span>
                                            <span>Add</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </form>
						</div>
					<% } %>
				</div>
			</div>
		</section>
	</body>
</html>