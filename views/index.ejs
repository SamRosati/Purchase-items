<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8"/>
        <link rel="stylesheet" href="bulma.min.css">
        <script defer src="https://use.fontawesome.com/releases/v5.3.1/js/all.js"> </script>
    </head>
    <body>
        <section class="section">
            <div class="maincolumns columns is-desktop is-vcentered">
                <div class="column is-10 is-offset-1 notification is-info is-light box container">
                    <div class="title">
                        Restaurants
                    </div>
                    <% if (locals.allRestaurants) { %>
                        <div class="table-container">
                        <table class="table is-bordered is-hoverable is-striped is-narrow">
                            <thead>
                            <tr>
                                <th> Name </th>
                                <th> Description </th>
                                <th> &nbsp; </th> <th> &nbsp; </th> </tr>
                            </thead>
                            <tbody>
                            <% for(let i=0; i < allRestaurants.length; i++) { %>
                            <tr>
                                <td><%= allRestaurants[i].name %></td>
                                <td><%= allRestaurants[i].description %></td>
                                <td>
                                    <a href="/deleteRestaurant?id=<%= allRestaurants[i].restaurant_id %>">
                                        <span class="icon is-small">
                                            <i class="fas fa-trash"></i>
                                        </span>
                                    </a>
                                </td>
                                <td>
                                    <a href="/showReviews?id=<%= allRestaurants[i].restaurant_id %>">
                                        <span class="icon is-small">
                                            <i class="fas fa-star"></i>
                                        </span>
                                    </a>
                                </td>
                            </tr>
                            <% } %>
                            </tbody>
                            <tfoot>
                                <tr> 
                                    <td colspan="4">
                                        There are <%= allRestaurants.length %> restaurants.
                                    </td> 
                                </tr>
                            </tfoot>
                        </table>

                        <form action="/addRestaurant" method="POST">
                            <h2 class="subtitle">Add New Restaurant</h2>
                            <div class="field is-horizontal">
                                <div class="field-body">
                                    <div class="field">
                                        <p class="control is-expanded">
                                            <input name="name" class="input" type="text" placeholder="Restaurant Name" required>
                                        </p>
                                    </div>
                                    <div class="field">
                                        <p class="control is-expanded">
                                            <input name="description" class="input" type="text" placeholder="Description" required>
                                        </p>
                                    </div>
                                    <div class="field">
                                        <button type="submit" class="button is-link">
                                            <span class="icon is-small">
                                                <i class="fas fa-plus"></i>
                                            </span>
                                            <span>Add</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </form>
                        </div>
                    <% } %>
                </div>
            </div>
        </section>
    </body>
</html>